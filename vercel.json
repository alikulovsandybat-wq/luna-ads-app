{
  "rewrites": [
    { "source": "/privacy", "destination": "/api/privacy" },
    { "source": "/terms", "destination": "/api/terms" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/connect", "destination": "/index.html" },
    { "source": "/campaigns", "destination": "/index.html" },
    { "source": "/campaigns/(.*)", "destination": "/index.html" },
    { "source": "/create", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-tg-data" }
      ]
    }
  ]
}