FRONTEND_URL=https://your-domain.vercel.app
LEMONSQUEEZY_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret
LEMONSQUEEZY_PLAN_1M_URL=https://yourstore.lemonsqueezy.com/checkout/buy/...
